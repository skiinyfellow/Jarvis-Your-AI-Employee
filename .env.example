# Jarvis Configuration
# Copy this file to .env and fill in your values

# Database Configuration
DB_PASSWORD=jarvis_secure_pass
DATABASE_URL=postgresql://jarvis:jarvis_secure_pass@localhost:5432/jarvis_db

# Ollama LLM Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Qdrant Vector Store
QDANT_URL=http://localhost:6333
QDANT_COLLECTION=jarvis_vectors

# Telegram Bot Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_user_id

# Obsidian Vault
OBSIDIAN_VAULT_PATH=/path/to/obsidian/vault
OBSIDIAN_AUTO_SYNC=true

# System Configuration
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
WORKERS=4

# Licensing
LICENSE_KEY=your_license_key_here
MAX_USERS=1
LICENSE_EXPIRES=2025-12-31

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_TIMEOUT=30

# Security
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1
